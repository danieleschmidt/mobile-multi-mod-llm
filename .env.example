# Mobile Multi-Modal LLM Environment Configuration
# Copy this file to .env and fill in your specific values

# ================================
# Project Configuration
# ================================
PROJECT_NAME=mobile-multi-mod-llm
PROJECT_VERSION=0.1.0
ENVIRONMENT=development  # development, staging, production

# ================================
# Python Configuration
# ================================
PYTHONPATH=./src
PYTHONUNBUFFERED=1
PYTHON_ENV=development

# ================================
# Model Configuration
# ================================
MODEL_NAME=mobile-mm-llm
MODEL_VERSION=v1.0
MODEL_PATH=./models
MODEL_CACHE_DIR=./models/cache
MAX_MODEL_SIZE_MB=35

# ================================
# Training Configuration
# ================================
BATCH_SIZE=32
LEARNING_RATE=1e-4
MAX_EPOCHS=100
EARLY_STOPPING_PATIENCE=10
GRADIENT_CLIP_VALUE=1.0
WEIGHT_DECAY=1e-5

# ================================
# Hardware Configuration
# ================================
DEVICE=auto  # auto, cpu, cuda, mps
NUM_WORKERS=4
PIN_MEMORY=true
MIXED_PRECISION=true

# Qualcomm Hexagon NPU
HEXAGON_SDK_ROOT=/opt/qcom/aistack/qairt/latest
HEXAGON_TOOLS_ROOT=/opt/qcom/aistack/qairt/latest/tools
USE_HEXAGON_NPU=false

# Apple Neural Engine
USE_CORE_ML=false
CORE_ML_OPTIMIZATION=true

# ================================
# Data Configuration
# ================================
DATA_ROOT=./data
DATASET_CACHE_DIR=./data/cache
MAX_SEQUENCE_LENGTH=128
IMAGE_SIZE=224
NUM_CHANNELS=3

# Training Data
TRAIN_DATA_PATH=./data/train
VAL_DATA_PATH=./data/val
TEST_DATA_PATH=./data/test
TRAIN_SPLIT_RATIO=0.8
VAL_SPLIT_RATIO=0.1
TEST_SPLIT_RATIO=0.1

# ================================
# Quantization Configuration
# ================================
QUANTIZATION_METHOD=int2  # int2, int4, int8, fp16
CALIBRATION_SAMPLES=1000
QUANTIZATION_BACKEND=qti_snpe  # qti_snpe, tflite, coreml
QAT_ENABLED=true

# ================================
# Mobile Platform Configuration
# ================================

# Android Configuration
ANDROID_SDK_ROOT=/opt/android-sdk
ANDROID_NDK_ROOT=/opt/android-ndk
ANDROID_MIN_API=24
ANDROID_TARGET_API=34
TFLITE_DELEGATE=hexagon  # hexagon, gpu, cpu

# iOS Configuration
IOS_DEPLOYMENT_TARGET=14.0
XCODE_VERSION=15.0
CORE_ML_TARGET=ios14

# ================================
# Logging Configuration
# ================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json, text
LOG_FILE=./logs/app.log
ENABLE_TENSORBOARD=true
TENSORBOARD_LOG_DIR=./logs/tensorboard

# ================================
# Experiment Tracking
# ================================

# Weights & Biases
WANDB_PROJECT=mobile-multi-mod-llm
WANDB_ENTITY=your-entity
WANDB_API_KEY=your-wandb-api-key
WANDB_MODE=online  # online, offline, disabled

# MLflow
MLFLOW_TRACKING_URI=./experiments/mlruns
MLFLOW_EXPERIMENT_NAME=mobile-mm-llm
MLFLOW_ARTIFACT_ROOT=./experiments/artifacts

# ================================
# Testing Configuration
# ================================
TEST_BATCH_SIZE=16
TEST_TIMEOUT=300
BENCHMARK_ITERATIONS=100
ACCURACY_THRESHOLD=0.90
LATENCY_THRESHOLD_MS=20
MEMORY_THRESHOLD_MB=150

# ================================
# Security Configuration
# ================================
MODEL_ENCRYPTION_KEY=your-encryption-key-here
VERIFY_MODEL_CHECKSUMS=true
SECURE_MODEL_LOADING=true

# ================================
# API Configuration
# ================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_TIMEOUT=30
ENABLE_API_DOCS=true
API_RATE_LIMIT=100

# ================================
# Cloud Configuration (Optional)
# ================================

# AWS (for model storage, training)
AWS_REGION=us-west-2
AWS_S3_BUCKET=your-model-bucket
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Google Cloud (for training, mobile deployment)
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json
GCS_BUCKET=your-model-bucket

# Hugging Face (for model sharing)
HF_TOKEN=your-huggingface-token
HF_REPO=your-username/mobile-mm-llm

# ================================
# Development Tools Configuration
# ================================

# Code Quality
BLACK_LINE_LENGTH=88
ISORT_PROFILE=black
MYPY_IGNORE_MISSING_IMPORTS=true
PYLINT_RCFILE=.pylintrc

# Pre-commit
PRE_COMMIT_ALLOW_NO_CONFIG=false
PRE_COMMIT_COLOR=auto

# Docker
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1

# ================================
# Mobile App Configuration
# ================================

# Android App
ANDROID_PACKAGE_NAME=com.terragon.mobilemm
ANDROID_APP_NAME=MobileMultiModal
ANDROID_VERSION_CODE=1
ANDROID_VERSION_NAME=1.0.0

# iOS App  
IOS_BUNDLE_ID=com.terragon.mobilemm
IOS_APP_NAME=MobileMultiModal
IOS_VERSION=1.0.0
IOS_BUILD_NUMBER=1

# ================================
# Performance Monitoring
# ================================
ENABLE_PROFILING=false
PROFILE_MEMORY=false
PROFILE_GPU=false
BENCHMARK_ON_STARTUP=false

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=mobile-mm-llm
OTEL_RESOURCE_ATTRIBUTES=service.name=mobile-mm-llm,service.version=0.1.0

# ================================
# Debug Configuration
# ================================
DEBUG=false
VERBOSE_LOGGING=false
SAVE_INTERMEDIATE_OUTPUTS=false
ENABLE_CUDA_DEBUGGING=false

# ================================
# Miscellaneous
# ================================
RANDOM_SEED=42
DETERMINISTIC_ALGORITHMS=true
CACHE_ENABLED=true
TEMP_DIR=/tmp/mobile-mm-llm